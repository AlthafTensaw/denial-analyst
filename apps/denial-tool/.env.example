# Denial Analysis Tool — environment variables.
#
# Copy this file to .env.local and fill in values for local development.
# .env.local is gitignored — NEVER commit filled-in env files.
#
# Required keys are validated by @tensaw/runtime's Zod config schema at
# module load (packages/runtime/src/config/index.ts). Missing or invalid
# values throw at app startup.

# === Required ===

# API base URL. In dev, MSW intercepts requests so the value just needs
# to be syntactically valid. In production this points at the Phase 1
# denial-tool API per tech spec §8: https://denial-tool-api.primrose.{aws-region}.aws
VITE_API_BASE_URL=http://localhost:8000

# AWS Cognito — tenant pool that issues JWTs per tech spec §3.3 / §16.1.
VITE_COGNITO_REGION=us-east-1
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_CLIENT_ID=

# App identity. Propagated into telemetry and audit events.
VITE_APP_ID=denial-tool
VITE_BUILD_VERSION=0.0.0-dev

# Stripe publishable key — REQUIRED by @tensaw/runtime's config schema
# even though the denial tool has no billing surface. This is a known
# platform debt item (see README.md "Platform handback list"); when the
# runtime makes Stripe optional, drop this key.
# Must start with pk_test_ or pk_live_.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_unused_runtime_validation_only

# === Optional ===

# Idle timeout in seconds. Inherits the platform default (900 = 15 min)
# if unset. Tech spec §10 / Frontend Handoff §10 Q7 — the denial tool
# does not implement custom idle handling.
# VITE_IDLE_TIMEOUT_SECONDS=900

# Sentry DSN for error tracking. Leave empty in dev.
# VITE_SENTRY_DSN=

# Feature flags endpoint. Leave empty in dev.
# VITE_FEATURE_FLAGS_URL=
